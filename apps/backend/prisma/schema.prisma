// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tournament {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  startAt     DateTime
  endAt       DateTime
  startGGId   String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sets        Set[]

  @@map("tournaments")
}

model Player {
  id          String   @id @default(cuid())
  name        String
  tag         String?
  startGGId   String?  @unique
  country     String?
  region      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  player1Sets Set[]    @relation("Player1Sets")
  player2Sets Set[]    @relation("Player2Sets")

  @@map("players")
}

model Set {
  id            String      @id @default(cuid())
  tournamentId  String
  roundName     String?
  totalGames    Int?
  streamName    String?
  winnerId      String?
  score         String?     // Format: "2-1"
  startGGId     String?     @unique
  startTime     DateTime?
  endTime       DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  tournament    Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player1       Player?     @relation("Player1Sets", fields: [player1Id], references: [id])
  player1Id     String?
  player2       Player?     @relation("Player2Sets", fields: [player2Id], references: [id])
  player2Id     String?
  vods          Vod[]

  @@map("sets")
}

model Vod {
  id             String    @id @default(cuid())
  setId          String?   // Optional: set unique (cas simple)
  eventStartGGId String?   // Start.gg event ID (VOD multi-sets)
  streamName     String?   // Nom du channel Twitch (filtre sets)
  tournamentId   String?   // Tournoi pour filtrage
  name           String?   // Display name (ex: "VOD Jour 1 - Stream A")
  sourceUrl      String    // Original VOD URL (Twitch, YouTube, etc.)
  filePath       String?   // Local path of the downloaded file
  processedUrl   String?   // Processed video URL
  status         VodStatus @default(PENDING)
  duration       Int?      // Duration in seconds
  fileSize       BigInt?   // File size in bytes
  resolution     String?   // e.g., "1920x1080"
  fps            Int?      // Frames per second
  startTime      Int?      // Start time in seconds from original VOD
  endTime        Int?      // End time in seconds from original VOD
  recordedAt     DateTime? // Stream start time (from yt-dlp metadata)
  events         Json?     // Array of GameScreenEvent détectés (final, après merge)
  totalChunks    Int?      // Nombre de chunks d'analyse
  completedChunks Int?     @default(0)
  metadata       Json?     // Additional metadata (stream info, etc.)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  set            Set?           @relation(fields: [setId], references: [id], onDelete: SetNull)
  clips          Clip[]
  chunkEvents    VodChunkEvent[]

  @@map("vods")
}

model VodChunkEvent {
  id         String @id @default(cuid())
  vodId      String
  chunkIndex Int
  events     Json   // GameScreenEvent[] pour ce chunk
  vod        Vod    @relation(fields: [vodId], references: [id], onDelete: Cascade)

  @@unique([vodId, chunkIndex])
  @@map("vod_chunk_events")
}

model Clip {
  id           String     @id @default(cuid())
  vodId        String
  setOrder     Int        // Position du set dans la VOD (1-based)
  setStartGGId String?    // Start.gg ID du set
  filePath     String
  startSeconds Int
  endSeconds   Int
  title          String?    // Titre éditable (ex: "Grand Final — Seidokan vs Ironsup")
  roundName      String?    // Round (ex: "Winners Semi-Final")
  players        String?    // "Player1 vs Player2"
  score          String?    // "3 - 1"
  thumbnailPath  String?    // Local path to thumbnail image
  youtubeVideoId String?    // YouTube video ID after upload
  status         ClipStatus @default(PENDING)
  createdAt      DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  vod          Vod        @relation(fields: [vodId], references: [id], onDelete: Cascade)

  @@map("clips")
}

enum ClipStatus {
  PENDING    // Auto-cut, pas encore reviewé
  APPROVED   // Validé par l'utilisateur, prêt pour upload
  UPLOADING  // En cours d'upload YouTube
  UPLOADED   // Uploadé avec succès
  FAILED     // Erreur d'upload
}

enum VodStatus {
  PENDING
  DOWNLOADING
  DOWNLOADED
  PROCESSING
  PROCESSED
  FAILED
  COMPLETED
}
